# Copy this file to .env (which is gitignored) and fill in a random secret.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
#
# This value is your MCP server's shared secret. Joey uses it as a Bearer
# token header; Claude embeds it in the URL path. Keep it private.
MCP_API_KEY=
