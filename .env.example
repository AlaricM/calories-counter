# Copy this file to .env (which is gitignored) and fill in a random secret.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
#
# This value becomes part of your MCP server's URL (see README) and acts as
# a shared-secret bearer token. Keep it private, like a password.
MCP_API_KEY=
