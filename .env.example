# Copy this file to .env (gitignored) and fill in OPENAI_API_KEY. The rest is
# optional. Per-user auth is stored (hashed) in DynamoDB — manage users with
# `npm run user`.

# OPENAI_API_KEY (REQUIRED) — the chat backend (gpt-5-nano) and the nutrition
# web-search both call OpenAI. Get one at https://platform.openai.com/api-keys.
# It's injected as a Lambda env var at deploy time (kept out of git via .env).
OPENAI_API_KEY=

# OPENAI_CHAT_MODEL / OPENAI_SEARCH_MODEL (optional) — override the models. The
# chat loop defaults to gpt-5-nano; the nutrition search needs a web-search-capable
# model (also gpt-5-nano by default). These are read by the Lambda at runtime; set
# them in the Lambda environment (or add them to the stack) if you want to change them.
# OPENAI_CHAT_MODEL=gpt-5-nano
# OPENAI_SEARCH_MODEL=gpt-5-nano

# ALERT_EMAIL (recommended) — email for AWS Budgets cost alerts. The stack creates
# a small monthly budget as a free-tier canary; set this to be emailed if the AWS
# bill ever moves. (OpenAI usage is billed separately by OpenAI.) Leave blank to
# create the budget silently.
#
# Setting this also enables the over-budget KILL SWITCH: if actual AWS spend crosses
# the budget limit, AWS Budgets attaches a Deny-all policy (lambda:* / s3:* /
# dynamodb:*) to the chat Lambda role, taking the app offline until you fix it.
ALERT_EMAIL=

# MONTHLY_BUDGET_USD (optional) — AWS budget ceiling in USD. Defaults to 1.
MONTHLY_BUDGET_USD=1

# USERS_TABLE_NAME (optional) — only needed by `npm run user` if you renamed the
# users table in the stack. Defaults to "food-tracker-users".
# USERS_TABLE_NAME=food-tracker-users
