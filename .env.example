# Copy this file to .env (gitignored) if you want cost alerts. Everything here
# is OPTIONAL — deploying no longer needs a shared secret, because auth is
# per-user and stored (hashed) in DynamoDB. Manage users with `npm run user`.

# ALERT_EMAIL (recommended) — email for AWS Budgets cost alerts. The stack
# creates a small monthly budget as a free-tier canary; set this to be emailed
# if anything ever costs money. Leave blank to create the budget silently.
ALERT_EMAIL=

# MONTHLY_BUDGET_USD (optional) — budget ceiling in USD. Defaults to 1.
MONTHLY_BUDGET_USD=1

# USERS_TABLE_NAME (optional) — only needed by `npm run user` if you renamed the
# users table in the stack. Defaults to "food-tracker-users".
# USERS_TABLE_NAME=food-tracker-users
