{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LambdaLogging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:<ACCOUNT_ID>:log-group:/aws/lambda/FoodTrackerMcpStack-*",
        "arn:aws:logs:us-east-1:<ACCOUNT_ID>:log-group:/aws/lambda/FoodTrackerMcpStack-*:*"
      ]
    },
    {
      "Sid": "AppDynamoAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:Query",
        "dynamodb:DeleteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:<ACCOUNT_ID>:table/food-tracker-items",
        "arn:aws:dynamodb:us-east-1:<ACCOUNT_ID>:table/food-tracker-daily",
        "arn:aws:dynamodb:us-east-1:<ACCOUNT_ID>:table/food-tracker-users"
      ]
    },
    {
      "Sid": "SiteDeploymentS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject*",
        "s3:GetBucket*",
        "s3:List*",
        "s3:PutObject*",
        "s3:DeleteObject*",
        "s3:Abort*"
      ],
      "Resource": [
        "arn:aws:s3:::cdk-hnb659fds-assets-<ACCOUNT_ID>-us-east-1",
        "arn:aws:s3:::cdk-hnb659fds-assets-<ACCOUNT_ID>-us-east-1/*",
        "arn:aws:s3:::foodtrackermcpstack-*",
        "arn:aws:s3:::foodtrackermcpstack-*/*"
      ]
    },
    {
      "Sid": "SiteDeploymentCloudFrontInvalidate",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetInvalidation"
      ],
      "Resource": "*"
    },
    {
      "Sid": "BudgetKillSwitchAttach",
      "Effect": "Allow",
      "Action": [
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy"
      ],
      "Resource": "arn:aws:iam::<ACCOUNT_ID>:role/FoodTrackerMcpStack-*"
    }
  ]
}
